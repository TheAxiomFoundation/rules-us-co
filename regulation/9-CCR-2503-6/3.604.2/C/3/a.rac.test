- name: ssi_recipient_is_excluded_from_assistance_unit
  period: "2026-04-02"
  input:
    client_receives_ssi_payments: true
  output:
    excluded_from_assistance_unit_due_to_ssi: true
- name: non_ssi_recipient_is_not_excluded_under_this_clause
  period: "2026-04-02"
  input:
    client_receives_ssi_payments: false
  output:
    excluded_from_assistance_unit_due_to_ssi: false
