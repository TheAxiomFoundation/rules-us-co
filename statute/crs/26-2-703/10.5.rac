"""
C.R.S. § 26-2-703(10.5)
Definitions

"Income" means any cash, payments, wages, in-kind receipts, inheritance, gifts,
prizes, rents, dividends, interest, and other gain or benefit in cash or in kind
received by members of an assistance unit.

Source note: encoded from the Colorado.Public.Law HTML snapshot retrieved on
2026-04-03.
"""

assistance_unit_member_receives_cash_payments_wages_in_kind_receipts_inheritance_gifts_prizes_rents_dividends_or_interest:
    entity: Person
    period: Month
    dtype: Boolean

assistance_unit_member_receives_other_gain_or_benefit_in_cash_or_in_kind:
    entity: Person
    period: Month
    dtype: Boolean

is_income:
    entity: Person
    period: Month
    dtype: Boolean
    from 2026-04-03:
        assistance_unit_member_receives_cash_payments_wages_in_kind_receipts_inheritance_gifts_prizes_rents_dividends_or_interest or
        assistance_unit_member_receives_other_gain_or_benefit_in_cash_or_in_kind
