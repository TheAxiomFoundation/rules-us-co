- name: qualifying_contract_is_irc
  period: "2026-04-03"
  input:
    contract_is_entered_into_by_participant_and_county_department: true
    contract_is_pursuant_to_section_26_2_708: true
  output:
    is_individual_responsibility_contract: true
- name: unrelated_contract_is_not_irc
  period: "2026-04-03"
  input:
    contract_is_entered_into_by_participant_and_county_department: true
    contract_is_pursuant_to_section_26_2_708: false
  output:
    is_individual_responsibility_contract: false
