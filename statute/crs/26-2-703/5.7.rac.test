- name: receipt_used_for_eligibility_is_countable_income
  period: "2026-04-03"
  input:
    receipt_is_gain_or_benefit_in_cash_or_in_kind: true
    receipt_is_used_to_determine_colorado_works_eligibility_or_benefit_amount: true
  output:
    is_countable_income: true
- name: unrelated_receipt_is_not_countable_income
  period: "2026-04-03"
  input:
    receipt_is_gain_or_benefit_in_cash_or_in_kind: true
    receipt_is_used_to_determine_colorado_works_eligibility_or_benefit_amount: false
  output:
    is_countable_income: false
